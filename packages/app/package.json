{
  "name": "@thinklish/app",
  "version": "0.1.0",
  "private": true,
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "unset ELECTRON_RUN_AS_NODE && electron-vite dev",
    "build": "electron-vite build",
    "preview": "unset ELECTRON_RUN_AS_NODE && electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "pnpm typecheck:node && pnpm typecheck:web",
    "lint": "eslint src/",
    "rebuild": "electron-rebuild -f -w better-sqlite3"
  },
  "dependencies": {
    "@thinklish/core": "workspace:*",
    "@thinklish/shared": "workspace:*",
    "@mozilla/readability": "^0.6.0",
    "better-sqlite3": "^12.8.0",
    "clsx": "^2.1.0",
    "jsdom": "^29.0.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^2.5.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@swc/core": "^1.15.24",
    "@types/better-sqlite3": "^7.6.0",
    "@types/jsdom": "^28.0.1",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.0",
    "electron": "^40.8.5",
    "electron-vite": "^5.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.6.0",
    "vite": "^6.4.0"
  }
}
