{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "paths": {
      "@thinklish/core": ["../core/src"],
      "@thinklish/core/*": ["../core/src/*"],
      "@thinklish/shared": ["../shared/src"],
      "@thinklish/shared/*": ["../shared/src/*"],
      "@renderer/*": ["./src/renderer/src/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.d.ts",
    "electron.vite.config.ts"
  ]
}
