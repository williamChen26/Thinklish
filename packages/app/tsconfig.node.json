{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "paths": {
      "@english-studio/core": ["../core/src"],
      "@english-studio/core/*": ["../core/src/*"],
      "@english-studio/shared": ["../shared/src"],
      "@english-studio/shared/*": ["../shared/src/*"]
    }
  },
  "include": [
    "src/main/**/*.ts",
    "src/main/**/*.d.ts",
    "src/preload/**/*.ts",
    "src/preload/**/*.d.ts",
    "electron.vite.config.ts"
  ]
}
