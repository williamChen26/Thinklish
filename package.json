{
  "name": "thinklish",
  "private": true,
  "version": "0.1.0",
  "description": "Think in English — immersive reading & deep understanding desktop app",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "rebuild": "pnpm --filter @thinklish/app rebuild",
    "pack": "turbo build && pnpm --filter @thinklish/app pack",
    "dist": "turbo build && pnpm --filter @thinklish/app dist",
    "dist:mac": "turbo build && pnpm --filter @thinklish/app dist:mac",
    "dist:win": "turbo build && pnpm --filter @thinklish/app dist:win"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "turbo": "^2.9.3",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
